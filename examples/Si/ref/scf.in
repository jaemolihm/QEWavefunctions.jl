 &control
    calculation     = 'scf'
    prefix          = 'si'
    restart_mode    = 'from_scratch'
    pseudo_dir      = '../../pseudo/'
    outdir          = './temp/'
    tprnfor         = .true.
    tstress         = .true.
 /
 &system
    ibrav           = 2
    celldm(1)       = 10.336
    ntyp            = 1
    nat             = 2
    ecutwfc         = 40
 /
 &electrons
    diagonalization = 'david'
    mixing_beta     = 0.7
    conv_thr        = 1.0d-13
 /
ATOMIC_SPECIES
  Si  28.085 Si.dojo.fr.ONCVv0.4.pbe.standard.upf
ATOMIC_POSITIONS {crystal}
 Si    0.00  0.00   0.00
 Si   -0.25  0.75  -0.25
K_POINTS automatic
4 4 4 0 0 0
